---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="IT Support That Just Works">

  <Header />

<section class="bg-gray-50">
  <div class="max-w-4xl mx-auto px-6 py-24">

    <div class="max-w-3xl">
      <p class="text-sm text-blue-600 font-medium mb-4">
        IT Support • Cloud • Networking
      </p>

      <h1 class="text-5xl md:text-6xl font-bold leading-tight mb-6">
        IT Support That Just Works
      </h1>

      <p class="text-lg text-gray-600 mb-8">
        Straightforward, reliable IT support for businesses that don’t have time
        for downtime, guesswork or overcomplicated setups.
      </p>

      <div class="flex gap-4">
        <a href="/contact" class="bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition">
          Get in touch
        </a>

        <a href="/services" class="px-6 py-3 border rounded-lg hover:bg-gray-50">
          View services
        </a>
      </div>
    </div>

  </div>
</section>
<section class="max-w-4xl mx-auto px-6 py-20">
	  <h2 class="text-2xl md:text-3xl font-semibold mb-10">Services</h2>

  <div class="grid md:grid-cols-2 gap-6">

  <div class="p-6 border rounded-xl hover:shadow-md transition">
    <h3 class="font-semibold mb-2">IT Support</h3>
    <p class="text-gray-600">
      Day-to-day support, troubleshooting and maintenance to keep everything running smoothly.
    </p>
  </div>

  <div class="p-6 border rounded-xl hover:shadow-md transition">
    <h3 class="font-semibold mb-2">Networking</h3>
    <p class="text-gray-600">
      Reliable network setup and configuration, from small offices to more complex environments.
    </p>
  </div>

  <div class="p-6 border rounded-xl hover:shadow-md transition">
    <h3 class="font-semibold mb-2">Cloud & Hosting</h3>
    <p class="text-gray-600">
      AWS, Cloudways and hosting environments designed properly from the start.
    </p>
  </div>

  <div class="p-6 border rounded-xl hover:shadow-md transition">
    <h3 class="font-semibold mb-2">Web & Systems</h3>
    <p class="text-gray-600">
      WordPress, custom systems and integrations that actually fit your business.
    </p>
  </div>

</div>
</section>
<Footer />
</Layout>