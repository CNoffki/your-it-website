---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout>
  <Header />
  <section class="bg-gradient-to-br from-[#1C8FBD] to-[#167da6] text-white">
    <div class="max-w-4xl mx-auto px-6 py-24">
      <p class="text-sm text-white/80 font-medium mb-4">
        IT Support • Cloud • Networking
      </p>

      <h1 class="text-5xl md:text-6xl font-bold leading-tight mb-6 text-white">
        IT Support That Just Works
      </h1>

      <p class="text-lg text-white/90 mb-8">
        Straightforward, reliable IT support for businesses that don’t have time
        for downtime, guesswork or overcomplicated setups.
      </p>

      <div class="flex gap-4">
        <a href="/contact" class="bg-white text-[#1C8FBD] px-6 py-3 rounded-lg font-medium hover:bg-gray-100 transition">
          Get in touch
        </a>
        <a href="/services" class="px-6 py-3 border border-white/40 text-white rounded-lg hover:bg-white/10 transition">
          View services
        </a>
      </div>
    </div>
  </section>

<section class="bg-gray-50 py-20">
  <div class="max-w-4xl mx-auto px-6">
    <h2 class="text-3xl md:text-4xl font-bold mb-10 text-gray-900">Services</h2>

    <div class="grid md:grid-cols-2 gap-6">

      <div class="p-6 bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-lg hover:-translate-y-1 hover:border-[#8CC63F] transition">
        <h3 class="font-semibold mb-2">IT Support</h3>
        <p class="text-gray-600">
          Day-to-day support, troubleshooting and maintenance to keep everything running smoothly.
        </p>
      </div>

      <div class="p-6 bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-lg hover:-translate-y-1 hover:border-[#8CC63F] transition">
        <h3 class="font-semibold mb-2">Networking</h3>
        <p class="text-gray-600">
          Reliable network setup and configuration, from small offices to more complex environments.
        </p>
      </div>

      <div class="p-6 bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-lg hover:-translate-y-1 hover:border-[#8CC63F] transition">
        <h3 class="font-semibold mb-2">Cloud & Hosting</h3>
        <p class="text-gray-600">
          AWS, Cloudways and hosting environments designed properly from the start.
        </p>
      </div>

      <div class="p-6 bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-lg hover:-translate-y-1 hover:border-[#8CC63F] transition">
        <h3 class="font-semibold mb-2">Web & Systems</h3>
        <p class="text-gray-600">
          WordPress, custom systems and integrations that actually fit your business.
        </p>
      </div>

    </div>
  </div>
</section>
</Layout>