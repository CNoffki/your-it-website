---
// Header component
---

<header class="bg-gray-900 border-b border-gray-800 text-white">
  <div class="max-w-4xl mx-auto px-6 py-3 flex items-center justify-between text-white">
    <!-- Logo -->
    <div class="flex items-center">
      <a href="/">
  <img src="/logo.png" alt="Your IT Support" class="h-12 w-auto" />
</a>
    </div>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex gap-8 text-base font-medium">
      <a href="/" class="text-white/90 hover:text-[#8CC63F] transition">Home</a>
      <a href="/services" class="text-white/90 hover:text-[#8CC63F] transition">Services</a>
      <a href="/contact" class="text-white/90 hover:text-[#8CC63F] transition">Contact</a>
    </nav>

    <!-- Mobile Menu Button -->
    <button id="menu-btn" class="md:hidden text-white text-xl">
      ☰
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden px-6 pb-4 bg-gray-900 text-white">
    <div class="flex flex-col gap-4 text-base">
      <a href="/" class="text-white/90 hover:text-[#8CC63F] transition">Home</a>
      <a href="/services" class="text-white/90 hover:text-[#8CC63F] transition">Services</a>
      <a href="/contact" class="text-white/90 hover:text-[#8CC63F] transition">Contact</a>
    </div>
  </div>

  <script>
    const btn = document.getElementById('menu-btn');
    const menu = document.getElementById('mobile-menu');

    btn?.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  </script>
</header>