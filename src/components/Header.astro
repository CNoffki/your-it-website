---
// Header component
---

<header class="border-b border-gray-200">
  <div class="max-w-4xl mx-auto px-6 py-3 flex items-center justify-between">
    <!-- Logo -->
    <div class="flex items-center">
      <img src="/logo.png" alt="Your IT Support" class="h-12 w-auto" />
    </div>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex gap-6 text-sm">
      <a href="/" class="hover:text-gray-900">Home</a>
      <a href="/services" class="hover:text-gray-900">Services</a>
      <a href="/contact" class="hover:text-gray-900">Contact</a>
    </nav>

    <!-- Mobile Menu Button -->
    <button id="menu-btn" class="md:hidden text-gray-700">
      ☰
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden px-6 pb-4">
    <div class="flex flex-col gap-3 text-sm">
      <a href="/" class="hover:text-gray-900">Home</a>
      <a href="/services" class="hover:text-gray-900">Services</a>
      <a href="/contact" class="hover:text-gray-900">Contact</a>
    </div>
  </div>

  <script>
    const btn = document.getElementById('menu-btn');
    const menu = document.getElementById('mobile-menu');

    btn?.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  </script>
</header>